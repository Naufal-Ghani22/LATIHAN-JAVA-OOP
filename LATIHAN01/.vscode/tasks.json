{
  "version": "2.0.0",
  "tasks": [
      {
          "label": "Compile Java",
          "type": "shell",
          "command": "javac",
          "args": [
              "-d",
              "./bin",
              "./src/com/latihan/App.java"
          ],
          "group": {
              "kind": "build",
              "isDefault": true
          }
      },
      {
          "label": "Run Java",
          "type": "shell",
          "command": "java",
          "args": [
              "-cp",
              "./bin",
              "com.latihan.App"
          ],
          "group": {
              "kind": "test",
              "isDefault": true
          }
      }
  ]
}
